#!/usr/bin/env bash
set -Eeuo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
    SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
    SOURCE_PATH="$(readlink "$SOURCE_PATH")"
    if [[ "$SOURCE_PATH" != /* ]]; then
        SOURCE_PATH="${SOURCE_DIR}/${SOURCE_PATH}"
    fi
done

SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd -P)"
DEFAULT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
CONFIG_FILE="${DOCWATCHER_CONFIG:-${HOME}/.local/doc-watcher/config.env}"

DOCWATCHER_ROOT="${DEFAULT_ROOT}"
BACKEND_HOST="127.0.0.1"
BACKEND_PORT="8000"
FRONTEND_HOST="127.0.0.1"
FRONTEND_PORT="5173"
BACKEND_RELOAD="1"
UV_BIN="uv"
PNPM_BIN="pnpm"
LOG_DIR="${HOME}/.local/doc-watcher/logs"
RUN_DIR="${HOME}/.local/doc-watcher/run"

usage() {
    cat <<'EOF'
Usage: scripts/doc-watcher <command>

Commands:
  init [--force]          Create ~/.local/doc-watcher/config.env and local run/log dirs
  start                   Start backend and frontend in the background
  up                      Run backend and frontend in the foreground
  stop                    Stop background processes
  restart                 Restart backend and frontend
  status                  Show process and HTTP health status
  logs [backend|frontend] Tail backend/frontend logs
  install-user-bin        Symlink this script to ~/.local/bin/doc-watcher
  uninstall-user-bin      Remove ~/.local/bin/doc-watcher symlink
  install-user-service    Install and start systemd --user service
  uninstall-user-service  Stop and remove systemd --user service
  help                    Show this help
EOF
}

quote_value() {
    printf '%q' "$1"
}

write_default_config() {
    local force="${1:-0}"
    local config_dir
    config_dir="$(dirname "$CONFIG_FILE")"
    mkdir -p "$config_dir" "$LOG_DIR" "$RUN_DIR"

    if [[ -f "$CONFIG_FILE" && "$force" != "1" ]]; then
        echo "Config already exists: $CONFIG_FILE"
        return 0
    fi

    cat >"$CONFIG_FILE" <<EOF
# DocWatcher local run config.
# This file is safe for shell source and systemd EnvironmentFile.

DOCWATCHER_ROOT=$(quote_value "$DEFAULT_ROOT")

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
BACKEND_RELOAD=1

UV_BIN=uv
PNPM_BIN=pnpm

LOG_DIR=$(quote_value "${HOME}/.local/doc-watcher/logs")
RUN_DIR=$(quote_value "${HOME}/.local/doc-watcher/run")

# Optional backend settings:
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# GITEA_URL=
# GITEA_TOKEN=
EOF

    echo "Created config: $CONFIG_FILE"
}

load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        write_default_config 0
    fi

    set -a
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
    set +a

    mkdir -p "$LOG_DIR" "$RUN_DIR"
}

backend_pid_file() {
    printf '%s/backend.pid' "$RUN_DIR"
}

frontend_pid_file() {
    printf '%s/frontend.pid' "$RUN_DIR"
}

require_command() {
    local command_name="$1"
    if ! command -v "$command_name" >/dev/null 2>&1; then
        echo "Missing required command: $command_name" >&2
        return 1
    fi
}

validate_repo() {
    if [[ ! -d "$DOCWATCHER_ROOT" ]]; then
        echo "DOCWATCHER_ROOT does not exist: $DOCWATCHER_ROOT" >&2
        return 1
    fi
    if [[ ! -f "$DOCWATCHER_ROOT/backend/pyproject.toml" ]]; then
        echo "Backend project not found under: $DOCWATCHER_ROOT/backend" >&2
        return 1
    fi
    if [[ ! -f "$DOCWATCHER_ROOT/frontend/package.json" ]]; then
        echo "Frontend project not found under: $DOCWATCHER_ROOT/frontend" >&2
        return 1
    fi
    require_command "$UV_BIN"
    require_command "$PNPM_BIN"
}

pid_is_running() {
    local pid="${1:-}"
    [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1
}

read_pid_file() {
    local pid_file="$1"
    if [[ -f "$pid_file" ]]; then
        tr -d '[:space:]' <"$pid_file"
    fi
}

service_is_running() {
    local pid_file="$1"
    local pid
    pid="$(read_pid_file "$pid_file")"
    pid_is_running "$pid"
}

port_in_use() {
    local host="$1"
    local port="$2"
    if ! command -v python3 >/dev/null 2>&1; then
        return 1
    fi
    python3 - "$host" "$port" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])
with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
    sock.settimeout(0.3)
    sys.exit(0 if sock.connect_ex((host, port)) == 0 else 1)
PY
}

ensure_ports_available() {
    if ! service_is_running "$(backend_pid_file)" && port_in_use "$BACKEND_HOST" "$BACKEND_PORT"; then
        echo "Backend port is already in use: ${BACKEND_HOST}:${BACKEND_PORT}" >&2
        return 1
    fi
    if ! service_is_running "$(frontend_pid_file)" && port_in_use "$FRONTEND_HOST" "$FRONTEND_PORT"; then
        echo "Frontend port is already in use: ${FRONTEND_HOST}:${FRONTEND_PORT}" >&2
        return 1
    fi
}

backend_command() {
    local reload_args=()
    if [[ "$BACKEND_RELOAD" == "1" || "$BACKEND_RELOAD" == "true" ]]; then
        reload_args=(--reload)
    fi

    cd "$DOCWATCHER_ROOT/backend"
    exec "$UV_BIN" run python -m uvicorn app.main:app "${reload_args[@]}" --host "$BACKEND_HOST" --port "$BACKEND_PORT"
}

frontend_command() {
    cd "$DOCWATCHER_ROOT/frontend"
    exec "$PNPM_BIN" dev --host "$FRONTEND_HOST" --port "$FRONTEND_PORT"
}

start_backend_background() {
    local pid_file
    pid_file="$(backend_pid_file)"
    if service_is_running "$pid_file"; then
        echo "Backend already running: $(read_pid_file "$pid_file")"
        return 0
    fi

    (
        backend_command
    ) >>"${LOG_DIR}/backend.log" 2>&1 &
    echo "$!" >"$pid_file"
}

start_frontend_background() {
    local pid_file
    pid_file="$(frontend_pid_file)"
    if service_is_running "$pid_file"; then
        echo "Frontend already running: $(read_pid_file "$pid_file")"
        return 0
    fi

    (
        frontend_command
    ) >>"${LOG_DIR}/frontend.log" 2>&1 &
    echo "$!" >"$pid_file"
}

verify_started() {
    sleep 1
    if ! service_is_running "$(backend_pid_file)"; then
        echo "Backend failed to start. Last log lines:" >&2
        tail -n 40 "${LOG_DIR}/backend.log" >&2 || true
        return 1
    fi
    if ! service_is_running "$(frontend_pid_file)"; then
        echo "Frontend failed to start. Last log lines:" >&2
        tail -n 40 "${LOG_DIR}/frontend.log" >&2 || true
        return 1
    fi
}

start_runtime() {
    load_config
    validate_repo
    ensure_ports_available
    start_backend_background
    start_frontend_background
    if ! verify_started; then
        stop_pid_file "frontend" "$(frontend_pid_file)"
        stop_pid_file "backend" "$(backend_pid_file)"
        return 1
    fi
    status_runtime
}

stop_pid_file() {
    local name="$1"
    local pid_file="$2"
    local pid
    pid="$(read_pid_file "$pid_file")"
    if ! pid_is_running "$pid"; then
        rm -f "$pid_file"
        echo "$name is not running"
        return 0
    fi

    echo "Stopping $name: $pid"
    kill "$pid" >/dev/null 2>&1 || true
    for _ in {1..20}; do
        if ! pid_is_running "$pid"; then
            rm -f "$pid_file"
            return 0
        fi
        sleep 0.5
    done

    echo "$name did not stop after TERM; sending KILL"
    kill -9 "$pid" >/dev/null 2>&1 || true
    rm -f "$pid_file"
}

stop_runtime() {
    load_config
    stop_pid_file "frontend" "$(frontend_pid_file)"
    stop_pid_file "backend" "$(backend_pid_file)"
}

http_status() {
    local name="$1"
    local url="$2"
    if command -v curl >/dev/null 2>&1 && curl -fsS "$url" >/dev/null 2>&1; then
        echo "$name HTTP: ok ($url)"
    else
        echo "$name HTTP: unavailable ($url)"
    fi
}

print_pid_status() {
    local name="$1"
    local pid_file="$2"
    local pid
    pid="$(read_pid_file "$pid_file")"
    if pid_is_running "$pid"; then
        echo "$name process: running (pid $pid)"
    else
        echo "$name process: stopped"
    fi
}

status_runtime() {
    load_config
    print_pid_status "backend" "$(backend_pid_file)"
    print_pid_status "frontend" "$(frontend_pid_file)"
    http_status "backend" "http://${BACKEND_HOST}:${BACKEND_PORT}/health"
    http_status "frontend" "http://${FRONTEND_HOST}:${FRONTEND_PORT}"
    echo "config: $CONFIG_FILE"
    echo "logs: $LOG_DIR"
}

tail_logs() {
    load_config
    local target="${1:-all}"
    case "$target" in
        backend)
            tail -n 80 -f "${LOG_DIR}/backend.log"
            ;;
        frontend)
            tail -n 80 -f "${LOG_DIR}/frontend.log"
            ;;
        all)
            touch "${LOG_DIR}/backend.log" "${LOG_DIR}/frontend.log"
            tail -n 80 -f "${LOG_DIR}/backend.log" "${LOG_DIR}/frontend.log"
            ;;
        *)
            echo "Unknown log target: $target" >&2
            return 1
            ;;
    esac
}

up_runtime() {
    load_config
    validate_repo
    ensure_ports_available

    local backend_pid=""
    local frontend_pid=""
    local exit_code=0

    cleanup() {
        trap - INT TERM EXIT
        if pid_is_running "$frontend_pid"; then
            kill "$frontend_pid" >/dev/null 2>&1 || true
        fi
        if pid_is_running "$backend_pid"; then
            kill "$backend_pid" >/dev/null 2>&1 || true
        fi
        wait "$frontend_pid" >/dev/null 2>&1 || true
        wait "$backend_pid" >/dev/null 2>&1 || true
        rm -f "$(frontend_pid_file)" "$(backend_pid_file)"
    }

    trap cleanup INT TERM EXIT

    (
        backend_command
    ) >>"${LOG_DIR}/backend.log" 2>&1 &
    backend_pid="$!"
    echo "$backend_pid" >"$(backend_pid_file)"

    (
        frontend_command
    ) >>"${LOG_DIR}/frontend.log" 2>&1 &
    frontend_pid="$!"
    echo "$frontend_pid" >"$(frontend_pid_file)"

    echo "DocWatcher running"
    echo "Backend:  http://${BACKEND_HOST}:${BACKEND_PORT}"
    echo "Frontend: http://${FRONTEND_HOST}:${FRONTEND_PORT}"
    echo "Logs:     ${LOG_DIR}"

    while true; do
        if ! pid_is_running "$backend_pid"; then
            wait "$backend_pid" >/dev/null 2>&1 || exit_code="$?"
            break
        fi
        if ! pid_is_running "$frontend_pid"; then
            wait "$frontend_pid" >/dev/null 2>&1 || exit_code="$?"
            break
        fi
        sleep 1
    done
    cleanup
    return "$exit_code"
}

install_user_service() {
    load_config
    local unit_dir="${HOME}/.config/systemd/user"
    local unit_file="${unit_dir}/doc-watcher.service"
    mkdir -p "$unit_dir"

    cat >"$unit_file" <<EOF
[Unit]
Description=DocWatcher local service
After=network.target

[Service]
Type=simple
WorkingDirectory=${DOCWATCHER_ROOT}
EnvironmentFile=${CONFIG_FILE}
ExecStart=/usr/bin/env bash "${SCRIPT_DIR}/doc-watcher" up
ExecStop=/usr/bin/env bash "${SCRIPT_DIR}/doc-watcher" stop
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
EOF

    systemctl --user daemon-reload
    systemctl --user enable --now doc-watcher.service
    echo "Installed user service: $unit_file"
}

uninstall_user_service() {
    local unit_file="${HOME}/.config/systemd/user/doc-watcher.service"
    systemctl --user disable --now doc-watcher.service >/dev/null 2>&1 || true
    rm -f "$unit_file"
    systemctl --user daemon-reload >/dev/null 2>&1 || true
    echo "Removed user service: $unit_file"
}

install_user_bin() {
    local force="${1:-0}"
    local bin_dir="${DOCWATCHER_BIN_DIR:-${HOME}/.local/bin}"
    local link_path="${bin_dir}/doc-watcher"
    local script_path="${SCRIPT_DIR}/doc-watcher"
    mkdir -p "$bin_dir"

    if [[ -e "$link_path" || -L "$link_path" ]]; then
        if [[ "$force" == "1" ]]; then
            rm -f "$link_path"
        elif [[ -L "$link_path" && "$(readlink "$link_path")" == "$script_path" ]]; then
            echo "Command already installed: $link_path"
            return 0
        else
            echo "Refusing to overwrite existing path: $link_path" >&2
            echo "Use: ./scripts/doc-watcher install-user-bin --force" >&2
            return 1
        fi
    fi

    ln -s "$script_path" "$link_path"
    echo "Installed command: $link_path"

    case ":${PATH}:" in
        *":${bin_dir}:"*)
            echo "You can now run: doc-watcher status"
            ;;
        *)
            echo "${bin_dir} is not in PATH."
            echo "Add this to your shell config, then open a new shell:"
            echo "  export PATH=\"${bin_dir}:\$PATH\""
            ;;
    esac
}

uninstall_user_bin() {
    local bin_dir="${DOCWATCHER_BIN_DIR:-${HOME}/.local/bin}"
    local link_path="${bin_dir}/doc-watcher"
    local script_path="${SCRIPT_DIR}/doc-watcher"

    if [[ ! -e "$link_path" && ! -L "$link_path" ]]; then
        echo "Command is not installed: $link_path"
        return 0
    fi
    if [[ ! -L "$link_path" || "$(readlink "$link_path")" != "$script_path" ]]; then
        echo "Refusing to remove non-DocWatcher path: $link_path" >&2
        return 1
    fi

    rm -f "$link_path"
    echo "Removed command: $link_path"
}

main() {
    local command="${1:-help}"
    shift || true

    case "$command" in
        init)
            if [[ "${1:-}" == "--force" ]]; then
                write_default_config 1
            else
                write_default_config 0
            fi
            ;;
        start)
            start_runtime
            ;;
        up)
            up_runtime
            ;;
        stop)
            stop_runtime
            ;;
        restart)
            stop_runtime
            start_runtime
            ;;
        status)
            status_runtime
            ;;
        logs)
            tail_logs "${1:-all}"
            ;;
        install-user-bin)
            if [[ "${1:-}" == "--force" ]]; then
                install_user_bin 1
            else
                install_user_bin 0
            fi
            ;;
        uninstall-user-bin)
            uninstall_user_bin
            ;;
        install-user-service)
            install_user_service
            ;;
        uninstall-user-service)
            uninstall_user_service
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            echo "Unknown command: $command" >&2
            usage >&2
            return 1
            ;;
    esac
}

main "$@"
